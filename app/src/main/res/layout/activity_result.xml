<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/resultHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_green"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="36dp"
            android:paddingBottom="20dp"
            android:paddingHorizontal="16dp">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:background="@null"
                android:padding="0dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diagnosis Result"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- DEMO MODE BANNER (shown only in demo mode) -->
        <TextView
            android:id="@+id/tvDemoBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️  DEMO MODE — Real TFLite model not loaded. Results are simulated."
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textAlignment="center"
            android:background="@drawable/bg_demo_banner"
            android:paddingVertical="10dp"
            android:paddingHorizontal="16dp"
            android:visibility="gone" />

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Crop + Status Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tvCropEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌽"
                        android:textSize="40sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tvCropName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Maize"
                            android:textColor="@color/text_gray"
                            android:textSize="13sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/tvStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DISEASE DETECTED"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@color/disease_color"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Disease Name -->
                <TextView
                    android:id="@+id/tvDiseaseName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maize Lethal Necrosis"
                    android:textColor="@color/text_dark"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Confidence Bar -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONFIDENCE SCORE"
                    android:textColor="@color/text_gray"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp" />

                <ProgressBar
                    android:id="@+id/confidenceBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="100"
                    android:progress="87"
                    android:progressTint="@color/disease_color"
                    android:progressBackgroundTint="#E0E0E0"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvConfidenceValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="87% confident"
                    android:textColor="@color/text_gray"
                    android:textSize="13sp"
                    android:textAlignment="textEnd" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Treatment Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💊"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Treatment Recommendation"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginStart="10dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTreatment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Treatment details appear here."
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="28dp">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="💾  Save to History"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:backgroundTint="@color/green_primary"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnScanAgain"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="🔄  Scan Again"
                android:textColor="@color/green_primary"
                android:textSize="15sp"
                android:backgroundTint="@color/white" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
