<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SmartAgric" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/green_accent</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/green_dark</item>
    </style>

    <style name="Theme.SmartAgric.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <style name="CropCardStyle" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">130dp</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <style name="CardTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="CardSubtitle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">#CCFFFFFF</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="SectionLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_gray</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
    </style>

</resources>
